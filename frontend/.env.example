# SAGE frontend — environment template. Copy to `.env.local` for local use.
# These values are compiled into the built JS bundle — never put secrets
# here. This project's frontend never needs a secret; it only needs to know
# where the backend lives.

# Full public URL of the hosted backend, including the /api suffix.
# Leave unset for local dev — Vite's dev-server proxy (vite.config.ts)
# forwards /api to http://localhost:8000 automatically.
VITE_API_BASE_URL=https://replace-with-your-railway-backend-url.up.railway.app/api
