# SAGE backend — environment template. Copy to `.env` for local use only;
# never commit a real `.env`. In hosted staging/production, set these as
# environment variables in the hosting provider's dashboard (e.g. Railway
# "Variables" tab) — never in a file that ships with the repo.

# --- Managed-service posture (do not change per user, only per deployment) --
SAGE_PROVIDER=val
# 1 = admin/dev deployment (provider status/testing endpoints enabled).
# 0 = standard deployment (provider concerns fully hidden from users).
SAGE_ADMIN_MODE=0

# --- Storage ------------------------------------------------------------
SAGE_DB_PATH=./sage.db
SAGE_ARTEFACT_ROOT=./artefacts
# Only needed if prompts/ is not at the default repo-relative location
# (the Docker image sets this itself — see Dockerfile).
# SAGE_PROMPTS_ROOT=/app/prompts

# --- CORS -----------------------------------------------------------------
# Comma-separated origins allowed to call this API. Set to the hosted
# frontend's public URL(s) — this is a public URL, not a secret.
SAGE_CORS_ORIGINS=http://localhost:5173

# --- VAL (production provider) --------------------------------------------
# The credential itself. NEVER commit a real value — paste it only into the
# hosting provider's secret/env dashboard.
VAL_API_KEY=replace-with-real-val-key

# Gateway facts — not secret, but override prompts/configs/val.json without
# needing a code change/redeploy. Leave unset to use the checked-in file.
VAL_BASE_URL=https://replace-with-val-gateway-base-url
VAL_API_STYLE=openai_chat
VAL_MODEL=replace-with-val-model-id

# --- Claude (fallback/test only — never production default) --------------
# ANTHROPIC_API_KEY=replace-with-real-anthropic-key
